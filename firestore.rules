rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function tenantId() {
      return request.auth.token.tenantId;
    }

    function role() {
      return request.auth.token.role;
    }

    function isOwnerOrAdmin() {
      return role() in ['OWNER', 'ADMIN'];
    }

    function isOwner() {
      return role() == 'OWNER';
    }

    function isManager() {
      return role() in ['OWNER', 'ADMIN', 'MANAGER'];
    }

    function belongsToTenant(tid) {
      return isAuth() && tenantId() == tid;
    }

    // ─── Tenants ─────────────────────────────────────────────────────────────

    match /tenants/{tenantId} {
      allow read: if belongsToTenant(tenantId);
      allow update: if belongsToTenant(tenantId) && isOwnerOrAdmin();
      allow create, delete: if false; // Uniquement via Admin SDK (setup)

      // ─── Users ─────────────────────────────────────────────────────────────
      match /users/{userId} {
        allow read: if belongsToTenant(tenantId);
        // Chaque utilisateur peut mettre à jour son propre profil,
        // mais jamais son propre rôle ou son propre statut actif/inactif —
        // ces deux champs ne peuvent être changés que par un OWNER/ADMIN
        // (vérifié via le claim du token, pas via le document lui-même).
        // Fix : un Admin pouvait promouvoir n'importe qui en Admin, ou
        // modifier un Admin existant, directement depuis le client — ça
        // contournait la restriction ajoutée côté serveur (seul le
        // Propriétaire accorde/retire le rôle Admin). Un simple Admin ne
        // peut donc plus toucher un document dont le rôle est ou deviendrait
        // ADMIN ; le Propriétaire, lui, garde un accès complet.
        allow update: if belongsToTenant(tenantId) &&
          (
            isOwner() ||
            (
              isOwnerOrAdmin() &&
              request.resource.data.role != 'ADMIN' &&
              resource.data.role != 'ADMIN'
            ) ||
            (
              request.auth.uid == userId &&
              request.resource.data.role == resource.data.role &&
              request.resource.data.isActive == resource.data.isActive
            )
          );
        allow create: if belongsToTenant(tenantId) &&
          (isOwner() || (isOwnerOrAdmin() && request.resource.data.role != 'ADMIN'));
        // Fix : "delete" était ouvert à isOwnerOrAdmin(), ce qui permettait à un
        // Admin de supprimer un Manager/Caissier directement depuis le client,
        // contournant entièrement le workflow de double vérification (demande +
        // justification + validation du Propriétaire) appliqué côté serveur dans
        // /api/users/delete. Seul le Propriétaire peut donc supprimer un document
        // utilisateur directement ; un Admin doit obligatoirement passer par la
        // route API (qui utilise l'Admin SDK et ignore ces règles).
        allow delete: if belongsToTenant(tenantId) && isOwner();
      }

      // ─── Demandes de suppression d'utilisateur (double vérification) ─────────
      match /user_deletion_requests/{requestId} {
        // Visible par Owner/Admin (l'Admin doit voir le statut de SA demande).
        allow read: if belongsToTenant(tenantId) && isOwnerOrAdmin();
        // Toute écriture passe par l'Admin SDK (/api/users/delete et
        // /api/users/deletion-requests/respond), qui applique la vraie logique
        // métier (justification obligatoire, un seul le Propriétaire peut
        // approuver/rejeter). Le client ne doit jamais pouvoir créer, modifier
        // ou faire disparaître une demande directement.
        allow write: if false;
      }

      // ─── Stores ────────────────────────────────────────────────────────────
      match /stores/{storeId} {
        allow read: if belongsToTenant(tenantId);
        allow create, update: if belongsToTenant(tenantId) && isOwnerOrAdmin();
        // Fix (demande explicite) : supprimer un magasin peut couper l'accès à
        // tout l'historique de produits/ventes/stock qui y est rattaché — trop
        // sensible pour un simple Admin. Réservé au Propriétaire.
        allow delete: if belongsToTenant(tenantId) && isOwner();
      }

      // ─── Subscriptions ─────────────────────────────────────────────────────
      match /subscriptions/{subId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if false; // Uniquement via Admin SDK
      }

      // ─── Categories ────────────────────────────────────────────────────────
      match /categories/{catId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if belongsToTenant(tenantId) && isManager();
      }

      // ─── Products ──────────────────────────────────────────────────────────
      match /products/{productId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if belongsToTenant(tenantId) && isManager();
      }

      // ─── Inventory ─────────────────────────────────────────────────────────
      match /inventory/{invId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if belongsToTenant(tenantId) && isManager();
      }

      match /inventory_movements/{movId} {
        allow read: if belongsToTenant(tenantId);
        allow create: if belongsToTenant(tenantId);
        allow update, delete: if false; // Les mouvements sont immuables
      }

      // ─── Customers ─────────────────────────────────────────────────────────
      match /customers/{customerId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if belongsToTenant(tenantId) && isManager();
      }

      // ─── Suppliers ─────────────────────────────────────────────────────────
      match /suppliers/{supplierId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if belongsToTenant(tenantId) && isManager();
      }

      // ─── Purchase orders (bons de commande fournisseurs) ────────────────────
      match /purchase_orders/{purchaseOrderId} {
        allow read: if belongsToTenant(tenantId);
        // Écriture uniquement via /api/purchase-orders/create et /receive
        // (Admin SDK) : le serveur fige les prix produits, calcule les totaux
        // et gère la réception transactionnelle du stock — jamais le client.
        allow write: if false;
      }

      // ─── Sale returns (retours / remboursements) ─────────────────────────────
      match /sale_returns/{returnId} {
        allow read: if belongsToTenant(tenantId);
        // Écriture uniquement via /api/sales/returns/create (Admin SDK) :
        // le serveur recalcule le montant remboursé depuis la vente d'origine.
        allow write: if false;
      }

      // ─── Sales ─────────────────────────────────────────────────────────────
      match /sales/{saleId} {
        allow read: if belongsToTenant(tenantId);
        // Créées uniquement par /api/pos/checkout (Admin SDK) — le serveur
        // recalcule les prix et le coût réel, jamais depuis le client.
        allow create: if false;
        // Annulation uniquement par /api/sales/cancel (Admin SDK) : le serveur
        // revérifie le statut et restaure le stock lui-même, jamais le client.
        allow update: if false;
        allow delete: if false;

        match /sale_items/{itemId} {
          allow read: if belongsToTenant(tenantId);
          allow create, update, delete: if false;
        }

        match /payments/{paymentId} {
          allow read: if belongsToTenant(tenantId);
          allow create, update, delete: if false;
        }

        // Coût réel / marge — réservé aux Managers+, jamais lisible par un
        // Caissier (contrairement à sale_items, lu par tous pour les reçus).
        match /cost_summary/{docId} {
          allow read: if belongsToTenant(tenantId) && isManager();
          allow write: if false;
        }
      }

      // ─── Credits ───────────────────────────────────────────────────────────
      match /credits/{creditId} {
        allow read: if belongsToTenant(tenantId);
        // Fix : "create" était ouvert à tout membre du tenant sans check de rôle,
        // alors que "update" exigeait déjà isManager(). En pratique la création
        // passe par l'API checkout (Admin SDK, qui ignore ces règles), donc ceci
        // ferme uniquement une brèche cliente non exploitée par l'app actuelle.
        allow create: if belongsToTenant(tenantId) && isManager();
        allow update: if belongsToTenant(tenantId) && isManager();
        allow delete: if false;

        match /credit_payments/{payId} {
          allow read: if belongsToTenant(tenantId);
          allow create: if belongsToTenant(tenantId) && isManager();
          allow update, delete: if false;
        }
      }

      // ─── Quotes ────────────────────────────────────────────────────────────
      match /quotes/{quoteId} {
        allow read: if belongsToTenant(tenantId);
        allow create: if belongsToTenant(tenantId) && isManager();
        allow update: if belongsToTenant(tenantId) && isManager();
        allow delete: if belongsToTenant(tenantId) && isOwnerOrAdmin();

        match /quote_items/{itemId} {
          allow read: if belongsToTenant(tenantId);
          allow write: if belongsToTenant(tenantId) && isManager();
        }
      }

      // ─── Cash registers ────────────────────────────────────────────────────
      match /cash_registers/{regId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if belongsToTenant(tenantId) && isManager();
      }

      match /cash_sessions/{sessionId} {
        allow read: if belongsToTenant(tenantId);
        // La clôture de caisse passe désormais uniquement par la route serveur
        // /api/cash-register/close (Admin SDK), qui recalcule les totaux à
        // partir des vraies ventes Firestore. Écriture directe interdite pour
        // empêcher un caissier de trafiquer l'écart de caisse.
        allow create, update, delete: if false;
      }

      // ─── Invoices ──────────────────────────────────────────────────────────
      match /invoices/{invoiceId} {
        allow read: if belongsToTenant(tenantId);
        allow create: if belongsToTenant(tenantId) && isManager();
        allow update: if belongsToTenant(tenantId) && isManager();
        allow delete: if belongsToTenant(tenantId) && isOwnerOrAdmin();
      }

      // ─── Alerts ────────────────────────────────────────────────────────────
      match /alerts/{alertId} {
        allow read: if belongsToTenant(tenantId);
        // Fix : "write" était ouvert à tout employé du tenant, qui pouvait donc
        // supprimer/modifier n'importe quelle alerte — y compris une alerte
        // sensible de demande de suppression d'utilisateur. Seule la mise à jour
        // (marquer lu/résolu) reste permise, réservée à Manager+. La création se
        // fait via l'Admin SDK (checkout, delete route...) et la suppression n'est
        // pas permise côté client (les alertes forment une trace, pas un journal
        // à nettoyer soi-même).
        allow create: if false;
        allow update: if belongsToTenant(tenantId) && isManager();
        allow delete: if false;
      }

      // ─── Notifications ─────────────────────────────────────────────────────
      match /notifications/{notifId} {
        allow read: if belongsToTenant(tenantId) &&
          (resource.data.userId == request.auth.uid || isOwnerOrAdmin());
        allow create: if belongsToTenant(tenantId);
        allow update: if belongsToTenant(tenantId) &&
          resource.data.userId == request.auth.uid;
        allow delete: if false;
      }

      // ─── Audit logs ────────────────────────────────────────────────────────
      match /audit_logs/{logId} {
        allow read: if belongsToTenant(tenantId) && isOwnerOrAdmin();
        // Fix : "create" était ouvert à tout membre du tenant, qui pouvait
        // donc écrire une entrée d'audit arbitraire (usurper un userId,
        // inventer une action) — une trace censée être fiable ne doit pas
        // être modifiable par le client. Le vrai flux d'écriture passe
        // exclusivement par lib/firebase/audit-log.ts (Admin SDK), qui
        // ignore ces règles ; aucun code client n'écrit ici (vérifié).
        allow create: if false;
        allow update, delete: if false; // Immuables
      }

      // ─── Error logs ────────────────────────────────────────────────────────
      match /error_logs/{logId} {
        allow read: if belongsToTenant(tenantId) && isOwnerOrAdmin();
        allow create: if belongsToTenant(tenantId);
        allow update, delete: if false;
      }
    }

    // Refuser tout le reste
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
