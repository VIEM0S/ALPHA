rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function tenantId() {
      return request.auth.token.tenantId;
    }

    function role() {
      return request.auth.token.role;
    }

    function isOwnerOrAdmin() {
      return role() in ['OWNER', 'ADMIN'];
    }

    function isManager() {
      return role() in ['OWNER', 'ADMIN', 'MANAGER'];
    }

    function belongsToTenant(tid) {
      return isAuth() && tenantId() == tid;
    }

    // ─── Tenants ─────────────────────────────────────────────────────────────

    match /tenants/{tenantId} {
      allow read: if belongsToTenant(tenantId);
      allow update: if belongsToTenant(tenantId) && isOwnerOrAdmin();
      allow create, delete: if false; // Uniquement via Admin SDK (setup)

      // ─── Users ─────────────────────────────────────────────────────────────
      match /users/{userId} {
        allow read: if belongsToTenant(tenantId);
        // Chaque utilisateur peut mettre à jour son propre profil,
        // mais jamais son propre rôle ou son propre statut actif/inactif —
        // ces deux champs ne peuvent être changés que par un OWNER/ADMIN
        // (vérifié via le claim du token, pas via le document lui-même).
        allow update: if belongsToTenant(tenantId) &&
          (
            isOwnerOrAdmin() ||
            (
              request.auth.uid == userId &&
              request.resource.data.role == resource.data.role &&
              request.resource.data.isActive == resource.data.isActive
            )
          );
        allow create, delete: if belongsToTenant(tenantId) && isOwnerOrAdmin();
      }

      // ─── Stores ────────────────────────────────────────────────────────────
      match /stores/{storeId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if belongsToTenant(tenantId) && isOwnerOrAdmin();
      }

      // ─── Subscriptions ─────────────────────────────────────────────────────
      match /subscriptions/{subId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if false; // Uniquement via Admin SDK
      }

      // ─── Categories ────────────────────────────────────────────────────────
      match /categories/{catId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if belongsToTenant(tenantId) && isManager();
      }

      // ─── Products ──────────────────────────────────────────────────────────
      match /products/{productId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if belongsToTenant(tenantId) && isManager();
      }

      // ─── Inventory ─────────────────────────────────────────────────────────
      match /inventory/{invId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if belongsToTenant(tenantId) && isManager();
      }

      match /inventory_movements/{movId} {
        allow read: if belongsToTenant(tenantId);
        allow create: if belongsToTenant(tenantId);
        allow update, delete: if false; // Les mouvements sont immuables
      }

      // ─── Customers ─────────────────────────────────────────────────────────
      match /customers/{customerId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if belongsToTenant(tenantId) && isManager();
      }

      // ─── Suppliers ─────────────────────────────────────────────────────────
      match /suppliers/{supplierId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if belongsToTenant(tenantId) && isManager();
      }

      // ─── Purchase orders (bons de commande fournisseurs) ────────────────────
      match /purchase_orders/{purchaseOrderId} {
        allow read: if belongsToTenant(tenantId);
        // Écriture uniquement via /api/purchase-orders/create et /receive
        // (Admin SDK) : le serveur fige les prix produits, calcule les totaux
        // et gère la réception transactionnelle du stock — jamais le client.
        allow write: if false;
      }

      // ─── Sale returns (retours / remboursements) ─────────────────────────────
      match /sale_returns/{returnId} {
        allow read: if belongsToTenant(tenantId);
        // Écriture uniquement via /api/sales/returns/create (Admin SDK) :
        // le serveur recalcule le montant remboursé depuis la vente d'origine.
        allow write: if false;
      }

      // ─── Sales ─────────────────────────────────────────────────────────────
      match /sales/{saleId} {
        allow read: if belongsToTenant(tenantId);
        // Créées uniquement par /api/pos/checkout (Admin SDK) — le serveur
        // recalcule les prix et le coût réel, jamais depuis le client.
        allow create: if false;
        // Annulation uniquement par /api/sales/cancel (Admin SDK) : le serveur
        // revérifie le statut et restaure le stock lui-même, jamais le client.
        allow update: if false;
        allow delete: if false;

        match /sale_items/{itemId} {
          allow read: if belongsToTenant(tenantId);
          allow create, update, delete: if false;
        }

        match /payments/{paymentId} {
          allow read: if belongsToTenant(tenantId);
          allow create, update, delete: if false;
        }

        // Coût réel / marge — réservé aux Managers+, jamais lisible par un
        // Caissier (contrairement à sale_items, lu par tous pour les reçus).
        match /cost_summary/{docId} {
          allow read: if belongsToTenant(tenantId) && isManager();
          allow write: if false;
        }
      }

      // ─── Credits ───────────────────────────────────────────────────────────
      match /credits/{creditId} {
        allow read: if belongsToTenant(tenantId);
        allow create: if belongsToTenant(tenantId);
        allow update: if belongsToTenant(tenantId) && isManager();
        allow delete: if false;

        match /credit_payments/{payId} {
          allow read: if belongsToTenant(tenantId);
          allow create: if belongsToTenant(tenantId) && isManager();
          allow update, delete: if false;
        }
      }

      // ─── Quotes ────────────────────────────────────────────────────────────
      match /quotes/{quoteId} {
        allow read: if belongsToTenant(tenantId);
        allow create: if belongsToTenant(tenantId) && isManager();
        allow update: if belongsToTenant(tenantId) && isManager();
        allow delete: if belongsToTenant(tenantId) && isOwnerOrAdmin();

        match /quote_items/{itemId} {
          allow read: if belongsToTenant(tenantId);
          allow write: if belongsToTenant(tenantId) && isManager();
        }
      }

      // ─── Cash registers ────────────────────────────────────────────────────
      match /cash_registers/{regId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if belongsToTenant(tenantId) && isManager();
      }

      match /cash_sessions/{sessionId} {
        allow read: if belongsToTenant(tenantId);
        // La clôture de caisse passe désormais uniquement par la route serveur
        // /api/cash-register/close (Admin SDK), qui recalcule les totaux à
        // partir des vraies ventes Firestore. Écriture directe interdite pour
        // empêcher un caissier de trafiquer l'écart de caisse.
        allow create, update, delete: if false;
      }

      // ─── Invoices ──────────────────────────────────────────────────────────
      match /invoices/{invoiceId} {
        allow read: if belongsToTenant(tenantId);
        allow create: if belongsToTenant(tenantId) && isManager();
        allow update: if belongsToTenant(tenantId) && isManager();
        allow delete: if belongsToTenant(tenantId) && isOwnerOrAdmin();
      }

      // ─── Alerts ────────────────────────────────────────────────────────────
      match /alerts/{alertId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if belongsToTenant(tenantId);
      }

      // ─── Notifications ─────────────────────────────────────────────────────
      match /notifications/{notifId} {
        allow read: if belongsToTenant(tenantId) &&
          (resource.data.userId == request.auth.uid || isOwnerOrAdmin());
        allow create: if belongsToTenant(tenantId);
        allow update: if belongsToTenant(tenantId) &&
          resource.data.userId == request.auth.uid;
        allow delete: if false;
      }

      // ─── Audit logs ────────────────────────────────────────────────────────
      match /audit_logs/{logId} {
        allow read: if belongsToTenant(tenantId) && isOwnerOrAdmin();
        allow create: if belongsToTenant(tenantId);
        allow update, delete: if false; // Immuables
      }

      // ─── Error logs ────────────────────────────────────────────────────────
      match /error_logs/{logId} {
        allow read: if belongsToTenant(tenantId) && isOwnerOrAdmin();
        allow create: if belongsToTenant(tenantId);
        allow update, delete: if false;
      }
    }

    // Refuser tout le reste
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
